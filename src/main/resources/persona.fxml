<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="base.controller.PersonaController">

    <TextField fx:id="txtNombre" promptText="Nombre" />
    <TextField fx:id="txtEmail" promptText="Email" />
    <TextField fx:id="txtNacionalidad" promptText="Nacionalidad" />
   <TextField fx:id="txtApodo" promptText="Apodo" />
    <ComboBox fx:id="cbTipoPersona" promptText="Selecciona Tipo" />
    
    
    <Button onAction="#guardar" text="Guardar" />
    <Button onAction="#borrar" text="Borrar seleccionado" />
   <Button mnemonicParsing="false" onAction="#volver" text="Volver" />

    <ListView fx:id="listaPersonas" prefHeight="132.0" prefWidth="248.0" />

</VBox>
